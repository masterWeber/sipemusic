generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Concert {
  id        String   @id @default(cuid())
  date      DateTime
  city      String
  venue     String
  ticketUrl String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
